---
// Search.astro - Global search component using Pagefind
---

<div id="search-container">
	<label for="search-input" class="visually-hidden">Search:</label>
	<input 
		type="search" 
		id="search-input" 
		placeholder="Search blog posts..."
		autocomplete="off"
	/>
	<div id="search-results" style="display: none;">
		<!-- Search results will be populated here -->
	</div>
</div>

<script is:inline>
	// Load Pagefind after the page loads
	async function loadPagefind() {
		// Only try to load Pagefind in production or after build
		if (window.location.hostname !== 'localhost' && window.location.hostname !== '127.0.0.1') {
			try {
				// Use dynamic import with Vite ignore to prevent build-time resolution
				const pagefindModule = await import(/* @vite-ignore */ '/marketing-blog/pagefind/pagefind.js');
				const pagefind = pagefindModule.default || pagefindModule;
				
				const searchInput = document.getElementById('search-input');
				const searchResults = document.getElementById('search-results');
				
				if (!searchInput || !searchResults) return;
				
				let searchTimeout;
				
				searchInput.addEventListener('input', async (e) => {
					const query = e.target?.value?.trim() || '';
					
					if (searchTimeout) {
						clearTimeout(searchTimeout);
					}
					
					if (query.length < 2) {
						searchResults.style.display = 'none';
						return;
					}
					
					// Debounce search
					searchTimeout = setTimeout(async () => {
						try {
							const results = await pagefind.search(query);
							
							if (results.results.length > 0) {
								const resultHtml = results.results.map(result => `
									<div style="margin-bottom: 1rem; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;">
										<h4 style="margin: 0 0 0.25rem 0;">
											<a href="${result.url}" style="text-decoration: none; color: inherit;">
												${result.data?.meta?.title || result.url}
											</a>
										</h4>
										<p style="margin: 0; font-size: 0.875rem; color: #666;">
											${result.data?.meta?.description || result.url}
										</p>
									</div>
								`).join('');
								
								searchResults.innerHTML = resultHtml;
								searchResults.style.display = 'block';
							} else {
								searchResults.innerHTML = '<p style="padding: 0.5rem;">No results found.</p>';
								searchResults.style.display = 'block';
							}
						} catch (error) {
							console.error('Search error:', error);
						}
					}, 300);
				});
				
				// Hide results when clicking outside
				document.addEventListener('click', (e) => {
					if (!searchInput?.contains(e.target) && !searchResults?.contains(e.target)) {
						searchResults.style.display = 'none';
					}
				});
			} catch (error) {
				console.error('Failed to load Pagefind:', error);
			}
		} else {
			// Development fallback
			const searchInput = document.getElementById('search-input');
			const searchResults = document.getElementById('search-results');
			
			if (searchInput && searchResults) {
				let searchTimeout;
				
				searchInput.addEventListener('input', async (e) => {
					const query = e.target?.value?.trim() || '';
					
					if (searchTimeout) {
						clearTimeout(searchTimeout);
					}
					
					if (query.length < 2) {
						searchResults.style.display = 'none';
						return;
					}
					
					// Debounce search
					searchTimeout = setTimeout(async () => {
						try {
							// Simulate search results for development
							const results = [
								{ url: '/marketing-blog/blog/hello-world', data: { meta: { title: 'Hello World', description: 'Welcome to my new marketing blog!' } } },
								{ url: '/marketing-blog/blog/digital-marketing-2026', data: { meta: { title: 'Digital Marketing Strategies for 2026', description: 'Explore the latest digital marketing trends and strategies.' } } },
								{ url: '/marketing-blog/blog/content-creation-tips', data: { meta: { title: 'Content Creation Tips for Beginners', description: 'Essential tips and tricks for creating engaging content.' } } }
							];
							
							if (results.length > 0) {
								const resultHtml = results.map(result => `
									<div style="margin-bottom: 1rem; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;">
										<h4 style="margin: 0 0 0.25rem 0;">
											<a href="${result.url}" style="text-decoration: none; color: inherit;">
												${result.data?.meta?.title || result.url}
											</a>
										</h4>
										<p style="margin: 0; font-size: 0.875rem; color: #666;">
											${result.data?.meta?.description || result.url}
										</p>
									</div>
								`).join('');
								
								searchResults.innerHTML = resultHtml;
								searchResults.style.display = 'block';
							} else {
								searchResults.innerHTML = '<p style="padding: 0.5rem;">No results found.</p>';
								searchResults.style.display = 'block';
							}
						} catch (error) {
							console.error('Search error:', error);
							searchResults.innerHTML = '<p style="padding: 0.5rem;">Error searching.</p>';
							searchResults.style.display = 'block';
						}
					}, 300);
				});
				
				// Hide results when clicking outside
				document.addEventListener('click', (e) => {
					if (!searchInput?.contains(e.target) && !searchResults?.contains(e.target)) {
						searchResults.style.display = 'none';
					}
				});
			}
		}
	}
	
	// Load Pagefind when DOM is ready
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', loadPagefind);
	} else {
		loadPagefind();
	}
</script>

<style>
	#search-container {
		position: relative;
		width: 100%;
		max-width: 400px;
		flex-shrink: 0;
	}
	
	@media (max-width: 767px) {
		#search-container {
			max-width: 100%;
		}
	}
	
	.visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
	
	#search-input {
		width: 100%;
		padding: 0.5rem 0.75rem;
		padding-left: 2.5rem;
		border: 1px solid #ccc;
		border-radius: 4px;
		font-size: 1rem;
		box-sizing: border-box;
	}
	
	#search-input::placeholder {
		color: #666;
	}
	
	#search-results {
		position: absolute;
		top: calc(100% + 4px);
		left: 0;
		right: 0;
		background: white;
		border: 1px solid #ccc;
		border-radius: 4px;
		max-height: 300px;
		overflow-y: auto;
		z-index: 1000;
		box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
	}
	
	#search-results a:hover {
		text-decoration: underline;
	}
</style>
