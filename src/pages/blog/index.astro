---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

// Get blog index content from CMS
const blogIndexContent = await getCollection('blogIndex');
const blogIndexData = blogIndexContent[0]; // Get the first (and only) blog index content

// Get blog posts
const blogPosts = await getCollection('blog');
// Sort posts by publication date (newest first)
const sortedPosts = blogPosts.sort((a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => 
	new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

// Format date as "April 6, 2026"
function formatDate(date: Date): string {
	return date.toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'long',
		day: 'numeric'
	});
}

// Fallback content if CMS content is not available
const title = blogIndexData?.data?.title || "Blog - Marketing Blog";
const description = blogIndexData?.data?.body || "Read the latest articles on digital marketing, content creation, SEO, and more.";
const rendered = blogIndexData?.rendered;
---

<BaseLayout 
	title={title}
	description={description}
>
	{rendered ? (
		<div set:html={rendered.html} />
	) : (
		<h1>Blog Posts</h1>
	)}
	
	{sortedPosts.length > 0 ? (
		<section>
			{sortedPosts.map((post: CollectionEntry<'blog'>) => (
				<article>
					<h2>
						<a href={`/marketing-blog/blog/${post.id}`}>
							{post.data.title}
						</a>
					</h2>
					<p>{post.data.description}</p>
					{post.data.tags && post.data.tags.length > 0 && (
						<p>
							<small>
								<strong>Tags:</strong> {post.data.tags.join(', ')}
							</small>
						</p>
					)}
					<time datetime={post.data.pubDate.toISOString()}>
						{formatDate(post.data.pubDate)}
					</time>
				</article>
			))}
		</section>
	) : (
		<p>No blog posts found.</p>
	)}
</BaseLayout>
