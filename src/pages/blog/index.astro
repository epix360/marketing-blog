---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import fs from 'fs/promises';
import { join } from 'path';

// Get blog index content from individual file
let blogIndexTitle = "Blog - Marketing Blog";
let blogIndexDescription = "Read the latest articles on digital marketing, content creation, SEO, and more.";
let blogIndexData = null;

try {
	const contentPath = join(process.cwd(), 'src/content/blogIndex/index.md');
	const fileContent = await fs.readFile(contentPath, 'utf-8');
	
	// Parse frontmatter and content
	const frontmatterMatch = fileContent.match(/^---\n([\s\S]*?)\n---/);
	if (frontmatterMatch) {
		const frontmatter = frontmatterMatch[1];
		const body = fileContent.replace(/^---\n[\s\S]*?\n---\n/, '');
		
		// Simple frontmatter parsing
		const titleMatch = frontmatter.match(/title:\s*"([^"]+)"/);
		
		blogIndexData = {
			data: {
				title: titleMatch?.[1] || blogIndexTitle,
				body: body.trim()
			}
		};
	}
} catch (error) {
	console.warn('Could not load blog index content:', error);
}

// Get blog posts
const blogPosts = await getCollection('blog');
// Sort posts by publication date (newest first)
const sortedPosts = blogPosts.sort((a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => 
	new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

// Format date as "April 6, 2026"
function formatDate(date: Date): string {
	return date.toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'long',
		day: 'numeric'
	});
}

// Use CMS content if available
const title = blogIndexData?.data?.title || blogIndexTitle;
const description = blogIndexData?.data?.body || blogIndexDescription;
---

<BaseLayout 
	title={title}
	description={description}
>
	{blogIndexData ? (
		<div set:html={blogIndexData.data.body} />
	) : (
		<h1>Blog Posts</h1>
	)}
	
	{sortedPosts.length > 0 ? (
		<section>
			{sortedPosts.map((post: CollectionEntry<'blog'>) => (
				<article>
					<h2>
						<a href={`/marketing-blog/blog/${post.id}`}>
							{post.data.title}
						</a>
					</h2>
					<p>{post.data.description}</p>
					{post.data.tags && post.data.tags.length > 0 && (
						<p>
							<small>
								<strong>Tags:</strong> {post.data.tags.join(', ')}
							</small>
						</p>
					)}
					<time datetime={post.data.pubDate.toISOString()}>
						{formatDate(post.data.pubDate)}
					</time>
				</article>
			))}
		</section>
	) : (
		<p>No blog posts found.</p>
	)}
</BaseLayout>
