---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

// Import available images
import heroHomeImage from '../../assets/images/hero-home.jpg';
import heroAboutImage from '../../assets/images/hero-about.jpg';
import batGeorgiaImage from '../../assets/images/Bat-Georgia.jpg';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post: CollectionEntry<'blog'>) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

// Format date as "April 6, 2026"
function formatDate(date: Date): string {
	return date.toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'long',
		day: 'numeric'
	});
}

// Image mapping function
function getImageSrc(imagePath: string) {
	const imageName = imagePath.replace('/images/', '');
	switch(imageName) {
		case 'hero-home.jpg':
			return heroHomeImage;
		case 'hero-about.jpg':
			return heroAboutImage;
		case 'Bat-Georgia.jpg':
			return batGeorgiaImage;
		default:
			return batGeorgiaImage; // fallback
	}
}

// Process markdown content - convert markdown to HTML and handle images
function processMarkdownContent(markdown: string | undefined): string {
	// Guard clause for undefined/null content
	if (!markdown || typeof markdown !== 'string') {
		return '';
	}
	
	let html = markdown;
	
	// Headers
	html = html.replace(/^# (.+)$/gm, '<h1>$1</h1>');
	html = html.replace(/^## (.+)$/gm, '<h2>$1</h2>');
	html = html.replace(/^### (.+)$/gm, '<h3>$1</h3>');
	
	// Lists
	html = html.replace(/^(\s*)- (.+)$/gm, '<li>$2</li>');
	html = html.replace(/^(\s*)\* (.+)$/gm, '<li>$2</li>');
	
	// Bold and italic
	html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
	html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
	
	// Images - add base path for GitHub Pages
	html = html.replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img src="/marketing-blog$2" alt="$1" style="max-width: 100%; border-radius: 8px;" />');
	
	// Links
	html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
	
	// Paragraphs - wrap lines that aren't already wrapped in tags
	const lines = html.split('\n');
	let result = '';
	let inList = false;
	
	for (const line of lines) {
		const trimmed = line.trim();
		
		if (trimmed.startsWith('<li>')) {
			if (!inList) {
				result += '<ul>';
				inList = true;
			}
			result += trimmed;
		} else if (inList && !trimmed.startsWith('<li>')) {
			result += '</ul>';
			inList = false;
			if (trimmed && !trimmed.startsWith('<')) {
				result += '<p>' + trimmed + '</p>';
			} else {
				result += trimmed;
			}
		} else if (trimmed && !trimmed.startsWith('<')) {
			result += '<p>' + trimmed + '</p>';
		} else {
			result += trimmed;
		}
	}
	
	if (inList) {
		result += '</ul>';
	}
	
	return result;
}

interface Props {
	post: CollectionEntry<'blog'>;
}

const { post }: Props = Astro.props;
const rendered = post.rendered;

// Process post image
let postImageSrc = null;
let postImageIsPublic = false;
let publicPostImagePath = null;

if (post.data.postImage) {
	const imageName = post.data.postImage.replace('/images/', '');
	
	// Check if this is a public folder webp image
	if (imageName.endsWith('.webp')) {
		postImageIsPublic = true;
		publicPostImagePath = '/marketing-blog' + post.data.postImage;
		postImageSrc = null;
	} else {
		// Legacy imported image
		postImageIsPublic = false;
		publicPostImagePath = null;
		postImageSrc = getImageSrc(post.data.postImage);
	}
}

// Process content to handle images
const processedContent = post.body ? processMarkdownContent(post.body) : '';

---

<BaseLayout 
	title={post.data.title}
	description={post.data.description}
	image={post.data.postImage}
	type="article"
	tags={post.data.tags}
	publishedDate={post.data.pubDate}
>
	<article>
		<header class="post-header">
			{postImageSrc && !postImageIsPublic && (
				<Image 
					src={postImageSrc} 
					alt={post.data.title}
					width={300}
					height={300}
					format="webp"
					quality={80}
					loading="eager"
					class="header-image"
				/>
			)}
			
			{postImageIsPublic && publicPostImagePath && (
				<img 
					src={publicPostImagePath} 
					alt={post.data.title}
					loading="eager"
					class="header-image"
				/>
			)}
			
			<div class="header-content">
				<h1>{post.data.title}</h1>
				<p><em>{post.data.description}</em></p>
				<time datetime={post.data.pubDate.toISOString()}>
					Published on {formatDate(post.data.pubDate)}
				</time>
				{post.data.tags && post.data.tags.length > 0 && (
					<p>
						<strong>Tags:</strong> {post.data.tags.join(', ')}
					</p>
				)}
			</div>
		</header>
		
		<div class="post-content" set:html={processedContent} />
		
		<footer>
			<p>
				<a href={`${import.meta.env.BASE_URL}blog/`}>← Back to Blog</a>
			</p>
		</footer>
	</article>
</BaseLayout>

<style>
	.post-header {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 1.5rem;
		margin-bottom: 2rem;
		max-width: 100%;
	}
	
	:global(.header-image) {
		max-width: 100%;
		width: 300px;
		height: 300px;
		object-fit: cover;
		border-radius: 8px;
		flex-shrink: 0;
	}
	
	.header-content {
		flex: 1;
		min-width: 0;
		text-align: left;
		max-width: 100%;
	}
	
	.header-content h1 {
		margin-top: 0;
	}
	
	/* Mobile: stack vertically with centered content (Pico's breakpoint at 768px) */
	@media (max-width: 768px) {
		.post-header {
			flex-direction: column;
			align-items: center;
		}
		
		:global(.header-image) {
			width: 100%;
			max-width: 300px;
			height: auto;
			aspect-ratio: 1;
		}
		
		.header-content {
			width: 100%;
			text-align: center;
		}
	}
</style>
