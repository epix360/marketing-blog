---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

// Import available images
import heroHomeImage from '../../assets/images/hero-home.jpg';
import heroAboutImage from '../../assets/images/hero-about.jpg';
import batGeorgiaImage from '../../assets/images/Bat-Georgia.jpg';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post: CollectionEntry<'blog'>) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

// Format date as "April 6, 2026"
function formatDate(date: Date): string {
	return date.toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'long',
		day: 'numeric'
	});
}

// Image mapping function
function getImageSrc(imagePath: string) {
	const imageName = imagePath.replace('/images/', '');
	switch(imageName) {
		case 'hero-home.jpg':
			return heroHomeImage;
		case 'hero-about.jpg':
			return heroAboutImage;
		case 'Bat-Georgia.jpg':
			return batGeorgiaImage;
		default:
			return batGeorgiaImage; // fallback
	}
}

// Process markdown content to handle images with Astro Image component
function processMarkdownImages(content: string): string {
	return content.replace(
		/!\[(.*?)\]\((.*?)\)/g,
		(match, alt, src) => {
			if (src.startsWith('/images/')) {
				// For images in /images/ directory, we'll handle them differently
				// This is a simplified approach - in production you'd want more robust handling
				return `<img src="${src}" alt="${alt}" loading="lazy" style="max-width: 100%; height: auto; border-radius: 8px; margin: 1rem 0;">`;
			}
			return match;
		}
	);
}

interface Props {
	post: CollectionEntry<'blog'>;
}

const { post }: Props = Astro.props;
const rendered = post.rendered;

// Process hero image
let heroImageSrc = null;
if (post.data.heroImage) {
	heroImageSrc = getImageSrc(post.data.heroImage);
}

// Process content to handle images
const processedContent = rendered ? processMarkdownImages(rendered.html) : '';
---

<BaseLayout 
	title={post.data.title}
	description={post.data.description}
	image={post.data.heroImage}
	type="article"
	tags={post.data.tags}
	publishedDate={post.data.pubDate}
>
	<article>
		<header>
			<h1>{post.data.title}</h1>
			<p><em>{post.data.description}</em></p>
			<time datetime={post.data.pubDate.toISOString()}>
				Published on {formatDate(post.data.pubDate)}
			</time>
			{post.data.tags && post.data.tags.length > 0 && (
				<p>
					<strong>Tags:</strong> {post.data.tags.join(', ')}
				</p>
			)}
		</header>
		
		{heroImageSrc && (
			<Image 
				src={heroImageSrc} 
				alt={post.data.title} 
				width={1200} 
				height={600}
				format="webp"
				quality={80}
				loading="eager"
				style="width: 100%; max-height: 600px; object-fit: cover; border-radius: 8px; margin: 2rem 0;"
			/>
		)}
		
		<hr />
		
		<section>
			<div set:html={processedContent} />
		</section>
		
		<footer>
			<p>
				<a href="/marketing-blog/blog/">← Back to Blog</a>
			</p>
		</footer>
	</article>
</BaseLayout>
