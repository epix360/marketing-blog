---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

// Import available images
import heroHomeImage from '../../assets/images/hero-home.jpg';
import heroAboutImage from '../../assets/images/hero-about.jpg';
import batGeorgiaImage from '../../assets/images/Bat-Georgia.jpg';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post: CollectionEntry<'blog'>) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

// Format date as "April 6, 2026"
function formatDate(date: Date): string {
	return date.toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'long',
		day: 'numeric'
	});
}

// Image mapping function
function getImageSrc(imagePath: string) {
	const imageName = imagePath.replace('/images/', '');
	switch(imageName) {
		case 'hero-home.jpg':
			return heroHomeImage;
		case 'hero-about.jpg':
			return heroAboutImage;
		case 'Bat-Georgia.jpg':
			return batGeorgiaImage;
		default:
			return batGeorgiaImage; // fallback
	}
}

// Process markdown content - convert markdown to HTML and handle images
function processMarkdownContent(markdown: string): string {
	let html = markdown;
	
	// Headers
	html = html.replace(/^# (.+)$/gm, '<h1>$1</h1>');
	html = html.replace(/^## (.+)$/gm, '<h2>$1</h2>');
	html = html.replace(/^### (.+)$/gm, '<h3>$1</h3>');
	
	// Lists
	html = html.replace(/^(\s*)- (.+)$/gm, '<li>$2</li>');
	html = html.replace(/^(\s*)\* (.+)$/gm, '<li>$2</li>');
	
	// Bold and italic
	html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
	html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
	
	// Images - add base path for GitHub Pages
	html = html.replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img src="/marketing-blog$2" alt="$1" style="max-width: 100%; border-radius: 8px;" />');
	
	// Links
	html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
	
	// Paragraphs - wrap lines that aren't already wrapped in tags
	const lines = html.split('\n');
	let result = '';
	let inList = false;
	
	for (const line of lines) {
		const trimmed = line.trim();
		
		if (trimmed.startsWith('<li>')) {
			if (!inList) {
				result += '<ul>';
				inList = true;
			}
			result += trimmed;
		} else if (inList && !trimmed.startsWith('<li>')) {
			result += '</ul>';
			inList = false;
			if (trimmed && !trimmed.startsWith('<')) {
				result += '<p>' + trimmed + '</p>';
			} else {
				result += trimmed;
			}
		} else if (trimmed && !trimmed.startsWith('<')) {
			result += '<p>' + trimmed + '</p>';
		} else {
			result += trimmed;
		}
	}
	
	if (inList) {
		result += '</ul>';
	}
	
	return result;
}

interface Props {
	post: CollectionEntry<'blog'>;
}

const { post }: Props = Astro.props;
const rendered = post.rendered;

// Process hero image
let heroImageSrc = null;
let heroImageIsPublic = false;
let publicHeroImagePath = null;

if (post.data.heroImage) {
	const imageName = post.data.heroImage.replace('/images/', '');
	
	// Check if this is a public folder webp image
	if (imageName.endsWith('.webp')) {
		heroImageIsPublic = true;
		publicHeroImagePath = '/marketing-blog' + post.data.heroImage;
		heroImageSrc = null;
	} else {
		// Legacy imported image
		heroImageIsPublic = false;
		publicHeroImagePath = null;
		heroImageSrc = getImageSrc(post.data.heroImage);
	}
}

// Process content to handle images
const processedContent = rendered ? processMarkdownContent(rendered.markdown) : '';

---

<BaseLayout 
	title={post.data.title}
	description={post.data.description}
	image={post.data.heroImage}
	type="article"
	tags={post.data.tags}
	publishedDate={post.data.pubDate}
>
	<article>
		<header>
			<h1>{post.data.title}</h1>
			<p><em>{post.data.description}</em></p>
			<time datetime={post.data.pubDate.toISOString()}>
				Published on {formatDate(post.data.pubDate)}
			</time>
			{post.data.tags && post.data.tags.length > 0 && (
				<p>
					<strong>Tags:</strong> {post.data.tags.join(', ')}
				</p>
			)}
		</header>
		
		{heroImageSrc && !heroImageIsPublic && (
			<Image 
				src={heroImageSrc} 
				alt={post.data.title} 
				width={1200} 
				height={600}
				format="webp"
				quality={80}
				loading="eager"
				style="width: 100%; max-height: 600px; object-fit: cover; border-radius: 8px; margin: 2rem 0;"
			/>
		)}
		
		{heroImageIsPublic && publicHeroImagePath && (
			<img 
				src={publicHeroImagePath} 
				alt={post.data.title} 
				loading="eager"
				style="width: 100%; max-height: 600px; object-fit: cover; border-radius: 8px; margin: 2rem 0;"
			/>
		)}
		
		<hr />
		
		<section>
			<div set:html={processedContent} />
		</section>
		
		<footer>
			<p>
				<a href="/marketing-blog/blog/">← Back to Blog</a>
			</p>
		</footer>
	</article>
</BaseLayout>
