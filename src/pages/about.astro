---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
	title="About - Marketing Blog"
	description="Learn about this marketing blog built with Astro and Pico CSS. Discover the technologies and features used."
>
	<h1>About This Blog</h1>
	<p>This is a static portfolio/blog showcasing modern web development with Astro and Pico CSS.</p>
	
	<h2>Technologies Used</h2>
	<ul>
		<li><strong>Astro</strong> - Static Site Generator</li>
		<li><strong>Pico CSS</strong> - Minimal CSS framework</li>
		<li><strong>TypeScript</strong> - Type-safe development</li>
	</ul>
	
	<h2>Features</h2>
	<ul>
		<li>Blazing fast static site generation</li>
		<li>Semantic HTML5 structure</li>
		<li>Responsive design out of the box</li>
		<li>Content collections for blog posts</li>
		<li>GitHub Pages ready deployment</li>
	</ul>
</BaseLayout>
