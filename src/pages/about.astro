---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

// Get about page content from CMS
const aboutContent = await getCollection('about');
const aboutData = aboutContent[0]; // Get the first (and only) about page content

// Fallback content if CMS content is not available
const title = aboutData?.data?.title || "About - Marketing Blog";
const description = aboutData?.data?.body || "Learn about this marketing blog built with Astro and Pico CSS. Discover the technologies and features used.";
const heroImage = aboutData?.data?.heroImage;
const rendered = aboutData?.rendered;
---

<BaseLayout 
	title={title}
	description={description}
	image={heroImage}
>
	{heroImage && (
		<img src={heroImage} alt="Hero image" style="width: 100%; max-height: 400px; object-fit: cover; border-radius: 8px; margin-bottom: 2rem;">
	)}
	
	{rendered ? (
		<div set:html={rendered.html} />
	) : (
		<>
			<h1>About This Blog</h1>
			<p>This is a static portfolio/blog showcasing modern web development with Astro and Pico CSS.</p>
			
			<h2>Technologies Used</h2>
			<ul>
				<li><strong>Astro</strong> - Static Site Generator</li>
				<li><strong>Pico CSS</strong> - Minimal CSS framework</li>
				<li><strong>TypeScript</strong> - Type-safe development</li>
			</ul>
			
			<h2>Features</h2>
			<ul>
				<li>Blazing fast static site generation</li>
				<li>Semantic HTML5 structure</li>
				<li>Responsive design out of the box</li>
				<li>Content collections for blog posts</li>
				<li>GitHub Pages ready deployment</li>
			</ul>
		</>
	)}
</BaseLayout>
