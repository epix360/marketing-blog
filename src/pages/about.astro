---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'fs/promises';
import { join } from 'path';

// Get about page content from individual file
let aboutData = null;
try {
	const contentPath = join(process.cwd(), 'src/content/about/index.md');
	const fileContent = await fs.readFile(contentPath, 'utf-8');
	
	// Parse frontmatter and content
	const frontmatterMatch = fileContent.match(/^---\n([\s\S]*?)\n---/);
	if (frontmatterMatch) {
		const frontmatter = frontmatterMatch[1];
		const body = fileContent.replace(/^---\n[\s\S]*?\n---\n/, '');
		
		// Simple frontmatter parsing
		const titleMatch = frontmatter.match(/title:\s*"([^"]+)"/);
		const heroImageMatch = frontmatter.match(/heroImage:\s*"([^"]+)"/);
		
		aboutData = {
			data: {
				title: titleMatch?.[1] || "About - Marketing Blog",
				body: body.trim(),
				heroImage: heroImageMatch?.[1]
			}
		};
	}
} catch (error) {
	console.warn('Could not load about content:', error);
}

// Use CMS content if available
const title = aboutData?.data?.title || "About - Marketing Blog";
const description = aboutData?.data?.body || "Learn about this marketing blog built with Astro and Pico CSS. Discover the technologies and features used.";
const heroImage = aboutData?.data?.heroImage;
---

<BaseLayout 
	title={title}
	description={description}
	image={heroImage}
>
	{heroImage && (
		<img src={heroImage} alt="Hero image" style="width: 100%; max-height: 400px; object-fit: cover; border-radius: 8px; margin-bottom: 2rem;">
	)}
	
	{aboutData ? (
		<div set:html={aboutData.data.body} />
	) : (
		<>
			<h1>About This Blog</h1>
			<p>This is a static portfolio/blog showcasing modern web development with Astro and Pico CSS.</p>
			
			<h2>Technologies Used</h2>
			<ul>
				<li><strong>Astro</strong> - Static Site Generator</li>
				<li><strong>Pico CSS</strong> - Minimal CSS framework</li>
				<li><strong>TypeScript</strong> - Type-safe development</li>
			</ul>
			
			<h2>Features</h2>
			<ul>
				<li>Blazing fast static site generation</li>
				<li>Semantic HTML5 structure</li>
				<li>Responsive design out of the box</li>
				<li>Content collections for blog posts</li>
				<li>GitHub Pages ready deployment</li>
			</ul>
		</>
	)}
</BaseLayout>
