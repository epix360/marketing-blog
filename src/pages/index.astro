---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

// Get home page content from CMS
const homeContent = await getCollection('home');
const homeData = homeContent[0]; // Get the first (and only) home page content

// Fallback content if CMS content is not available
const title = homeData?.data?.title || "Marketing Blog - Home";
const description = homeData?.data?.body || "Welcome to my marketing blog! Explore articles on digital marketing, content creation, and SEO strategies.";
const heroImage = homeData?.data?.heroImage;
const rendered = homeData?.rendered;
---

<BaseLayout 
	title={title}
	description={description}
	image={heroImage}
>
	{heroImage && (
		<img src={heroImage} alt="Hero image" style="width: 100%; max-height: 400px; object-fit: cover; border-radius: 8px; margin-bottom: 2rem;">
	)}
	
	{rendered ? (
		<div set:html={rendered.html} />
	) : (
		<>
			<h1>Welcome to My Marketing Blog</h1>
			<p>This is a static portfolio/blog built with Astro and Pico CSS.</p>
			<p>Explore the navigation above to learn more about this project.</p>
		</>
	)}
</BaseLayout>
