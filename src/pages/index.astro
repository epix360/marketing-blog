---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'fs/promises';
import { join } from 'path';

// Simple markdown to HTML converter
function markdownToHtml(markdown: string): string {
	let html = markdown;
	
	// Headers
	html = html.replace(/^# (.+)$/gm, '<h1>$1</h1>');
	html = html.replace(/^## (.+)$/gm, '<h2>$1</h2>');
	html = html.replace(/^### (.+)$/gm, '<h3>$1</h3>');
	
	// Lists
	html = html.replace(/^- (.+)$/gm, '<li>$1</li>');
	html = html.replace(/^\* (.+)$/gm, '<li>$1</li>');
	
	// Bold and italic
	html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
	html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
	
	// Paragraphs
	html = html.replace(/\n\n/g, '</p><p>');
	html = html.replace(/\n/g, '<br>');
	
	// Wrap in paragraphs
	const lines = html.split('<br>');
	let result = '';
	for (let i = 0; i < lines.length; i++) {
		const line = lines[i].trim();
		if (line && !line.startsWith('<') && !line.startsWith('</')) {
			result += '<p>' + line + '</p>';
		} else {
			result += line;
		}
	}
	
	return result;
}

// Get home page content from individual file
let homeData = null;
try {
	const contentPath = join(process.cwd(), 'src/content/home/index.md');
	const fileContent = await fs.readFile(contentPath, 'utf-8');
	
	console.log('Raw file content:', fileContent);
	
	// Parse frontmatter and content - handle multi-line frontmatter
	const frontmatterStart = fileContent.indexOf('---');
	if (frontmatterStart !== -1) {
		const secondDashIndex = fileContent.indexOf('---', frontmatterStart + 3);
		if (secondDashIndex !== -1) {
			const frontmatter = fileContent.substring(frontmatterStart + 3, secondDashIndex);
			const body = fileContent.substring(secondDashIndex + 3);
			
			console.log('Frontmatter extracted:', frontmatter);
			console.log('Body extracted (raw):', body);
			console.log('Body extracted (trimmed):', body.trim());
			
			// Simple frontmatter parsing
			const titleMatch = frontmatter.match(/title:\s*"([^"]+)"/);
			const heroImageMatch = frontmatter.match(/heroImage:\s*"([^"]+)"/);
			
			homeData = {
				data: {
					title: titleMatch?.[1] || "Marketing Blog - Home",
					body: body.trim(),
					heroImage: heroImageMatch?.[1]
				}
			};
		}
	}
} catch (error) {
	console.warn('Could not load home content:', error);
}

// Use CMS content if available
const title = homeData?.data?.title || "Marketing Blog - Home";
const description = homeData?.data?.body || "Welcome to my marketing blog! Explore articles on digital marketing, content creation, and SEO strategies.";
const heroImage = homeData?.data?.heroImage;
const content = homeData?.data?.body || "";

console.log('Content loaded:', content);
console.log('Home data:', homeData);
const renderedContent = content ? markdownToHtml(content) : "";
console.log('Rendered content:', renderedContent);
---

<BaseLayout 
	title={title}
	description={description}
	image={heroImage}
>
	{heroImage && (
		<img src={heroImage} alt="Hero image" style="width: 100%; max-height: 400px; object-fit: cover; border-radius: 8px; margin-bottom: 2rem;">
	)}
	
	{homeData ? (
		<div set:html={renderedContent} />
	) : (
		<>
			<h1>Welcome to My Marketing Blog</h1>
			<p>This is a static portfolio/blog built with Astro and Pico CSS.</p>
			<p>Explore the navigation above to learn more about this project.</p>
		</>
	)}
</BaseLayout>
