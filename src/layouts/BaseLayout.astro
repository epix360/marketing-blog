---
import '@picocss/pico';
import '../styles/custom.css';
import Search from '../components/Search.astro';
import Analytics from '../components/Analytics.astro';
import SEO from '../components/SEO.astro';

export interface Props {
	title: string;
	description?: string;
	image?: string;
	type?: string;
	tags?: string[];
	publishedDate?: Date;
}

const { 
	title, 
	description, 
	image, 
	type = 'website', 
	tags, 
	publishedDate 
} = Astro.props;
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
	<head>
		<SEO 
			title={title}
			description={description}
			image={image}
			type={type}
			tags={tags}
			publishedDate={publishedDate}
		/>
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
		<meta name="generator" content={Astro.generator} />
	</head>
	<body>
		<header>
			<nav class="main-nav">
				<ul>
					<li><strong>Marketing Blog</strong></li>
				</ul>
				<ul class="nav-links">
					<li><a href={import.meta.env.BASE_URL}>Home</a></li>
					<li><a href={`${import.meta.env.BASE_URL}blog`}>Blog</a></li>
					<li><a href={`${import.meta.env.BASE_URL}about`}>About</a></li>
					<li><a href={`${import.meta.env.BASE_URL}contact`}>Contact</a></li>
				</ul>
				<Search />
			</nav>
		</header>
		
		<main class="container">
			<slot />
		</main>
		
		<footer>
			<nav>
				<ul>
					<li>© {currentYear} Marketing Blog. All rights reserved.</li>
				</ul>
			</nav>
		</footer>
		<Analytics />
	</body>
</html>

<style>
	/* Ensure html and body don't constrain width */
	html, body {
    max-width: 1400px;
    margin: 0 auto;
	}

	ul {
		list-style-position: inside;
	}
	
	/* Mobile-first: Default styles for mobile */
	.main-nav {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		width: 100%;
	}
	
	.nav-links {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 1rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}
	
	/* Mobile: Override Pico's container to be truly full-width */
	@media (max-width: 767px) {
		main.container,
		body > header,
		body > footer {
			max-width: 100% !important;
			width: 100% !important;
			padding-left: 1rem !important;
			padding-right: 1rem !important;
			margin-left: 0 !important;
			margin-right: 0 !important;
		}
	}
	
	/* Desktop: Horizontal layout with nav links left, search right */
	@media (min-width: 768px) {
		.main-nav {
			flex-direction: row;
			justify-content: flex-start;
			align-items: center;
			gap: 1rem;
		}
		
		.main-nav > ul:first-child {
			margin-right: auto;
		}
		
		.nav-links {
			flex-wrap: nowrap;
		}
		
		.main-nav > #search-container,
		.main-nav > [id="search-container"] {
			margin-left: auto;
		}
	}
</style>
